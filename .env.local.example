# Vercel Blob read/write token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Anthropic Messages API (AI 인사이트)
ANTHROPIC_API_KEY=sk-ant-...

# Dashboard 로그인 비밀번호
DASHBOARD_PASSWORD=madup

# Madup 내부 API Proxy Gateway (Slack / Dropbox / Google Sheets)
MADUP_PROXY_BASE_URL=https://api-auth.madup-dct.site
MADUP_PROXY_API_KEY=mk_xxx

# Dropbox 리포트 루트 (NEW_2026 까지)
DROPBOX_REPORT_ROOT=/광고사업부/4. 광고주/메리츠파트너스/7. 리포트/3. 통합동의 리포트/NEW_2026

# Slack 알림 채널 ID
SLACK_NOTIFY_CHANNEL=C085E1L2W4E

# Vercel Cron 인증 시크릿 (vercel.json crons → /api/cron/ingest Authorization: Bearer ${CRON_SECRET})
CRON_SECRET=change-me-random-hex
